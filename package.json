{
  "name": "slot-machine-v2",
  "version": "1.0.0",
  "description": "Slot Machine Game",
  "type": "module",
  "scripts": {
    "lint": "npm run lint:html && npm run lint:css && npm run lint:js",
    "lint:html": "htmlhint \"**/*.html\" --ignore \"node_modules/**\"",
    "lint:css": "stylelint \"**/*.css\" --ignore-pattern \"node_modules/**\" --allow-empty-input",
    "lint:js": "eslint .",
    "lint:fix": "npm run lint:css -- --fix && npm run lint:js -- --fix"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "eslint": "^9.25.0",
    "globals": "^16.0.0",
    "htmlhint": "^1.1.4",
    "playwright": "^1.59.1",
    "stylelint": "^16.18.0",
    "stylelint-config-standard": "^37.0.0",
    "vitest": "^4.1.5"
  }
}
